<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <!-- 차량 타입 -->
    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5" maxSpeed="13.89"/>

    <!-- 경로 정의 -->
    <route id="N_S" edges="N2C C2S"/>
    <route id="N_E" edges="N2C C2E"/>
    <route id="N_W" edges="N2C C2W"/>
    <route id="S_N" edges="S2C C2N"/>
    <route id="S_E" edges="S2C C2E"/>
    <route id="S_W" edges="S2C C2W"/>
    <route id="E_N" edges="E2C C2N"/>
    <route id="E_S" edges="E2C C2S"/>
    <route id="E_W" edges="E2C C2W"/>
    <route id="W_N" edges="W2C C2N"/>
    <route id="W_S" edges="W2C C2S"/>
    <route id="W_E" edges="W2C C2E"/>

    <!-- 차량 흐름 (vehsPerHour로 밀도 조절) -->
    <flow id="f_NS" type="car" route="N_S" begin="0" end="3600" vehsPerHour="400"/>
    <flow id="f_NE" type="car" route="N_E" begin="0" end="3600" vehsPerHour="100"/>
    <flow id="f_NW" type="car" route="N_W" begin="0" end="3600" vehsPerHour="100"/>
    <flow id="f_SN" type="car" route="S_N" begin="0" end="3600" vehsPerHour="400"/>
    <flow id="f_SE" type="car" route="S_E" begin="0" end="3600" vehsPerHour="100"/>
    <flow id="f_SW" type="car" route="S_W" begin="0" end="3600" vehsPerHour="100"/>
    <flow id="f_EN" type="car" route="E_N" begin="0" end="3600" vehsPerHour="100"/>
    <flow id="f_ES" type="car" route="E_S" begin="0" end="3600" vehsPerHour="100"/>
    <flow id="f_EW" type="car" route="E_W" begin="0" end="3600" vehsPerHour="300"/>
    <flow id="f_WN" type="car" route="W_N" begin="0" end="3600" vehsPerHour="100"/>
    <flow id="f_WS" type="car" route="W_S" begin="0" end="3600" vehsPerHour="100"/>
    <flow id="f_WE" type="car" route="W_E" begin="0" end="3600" vehsPerHour="300"/>

</routes>